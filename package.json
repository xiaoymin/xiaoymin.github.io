{
  "name": "xiaoymin-github-io",
  "type": "module",
  "version": "6.1.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro check && ASTRO_TELEMETRY_DISABLED=1 astro build && pagefind --site dist && node scripts/copy-static-assets.mjs",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "sync": "ASTRO_TELEMETRY_DISABLED=1 astro sync",
    "astro": "ASTRO_TELEMETRY_DISABLED=1 astro",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "4.3.0",
    "astro": "^6.4.2",
    "dayjs": "^1.11.21",
    "lodash.kebabcase": "^4.1.1",
    "rehype-callouts": "^2.1.2",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@pagefind/default-ui": "^1.5.2",
    "@shikijs/transformers": "^4.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/lodash.kebabcase": "^4.1.9",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "pagefind": "^1.5.2",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  }
