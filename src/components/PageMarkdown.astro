---
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

type Props = {
  entry: string;
};

const { entry } = Astro.props;
const page = await getEntry("pages", entry);

if (!page) {
  throw new Error(`Missing content entry: ${entry}`);
}

const { Content } = await render(page);
---

<Layout
  title={`${page.data.title} | ${config.site.title}`}
  description={page.data.description}
  keywords={page.data.keywords}
  ogImage={page.data.ogImage}
  canonicalURL={page.data.canonicalURL}
>
  <Header />
  <Breadcrumb />
  <Main pageTitle={page.data.title} class="app-prose">
    <Content />
  </Main>
  <Footer />
</Layout>
